    <!-- http://www.eudamed.eu/ontology#SelfTestDevice -->


    <owl:Class rdf:about="http://www.eudamed.eu/ontology#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.eudamed.eu/ontology#Device"/>
