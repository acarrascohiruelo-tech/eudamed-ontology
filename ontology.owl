    <!-- http://www.eudamed.eu/ontology#SeriousIncident -->


    <owl:Class rdf:about="http://www.eudamed.eu/ontology#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.eudamed.eu/ontology#Incident"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.eudamed.eu/ontology#hasAssociatedRisk"/>
                <owl:someValuesFrom rdf:resource="http://www.eudamed.eu/ontology#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>An incident leading to death or serious deterioration of a patient&apos;s health. Must have at least one associated risk.</rdfs:comment>
        <rdfs:label>Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.eudamed.eu/ontology#SingleUseDevice -->


    <owl:Class rdf:about="http://www.eudamed.eu/ontology#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.eudamed.eu/ontology#Device"/>
        <rdfs:comment>A medical device intended to be used on one individual during a single procedure.</rdfs:comment>
        <rdfs:label>Single Use Device</rdfs:label>
    </owl:Class>
    


