  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A comprehensive ontology representing high-risk medical devices, their manufacturers, associated risks, incident reports, and field safety corrective actions (FSCAs), based on the European MDR and IVDR regulatory frameworks."
