:IVDR rdf:type owl:NamedIndividual ,
               :Regulation ;
      rdfs:comment "In Vitro Diagnostic Regulation (EU 2017/746)." ;
      rdfs:label "IVDR" .


###  http://www.eudamed.eu/ontology#Ireland
:Ireland rdf:type owl:NamedIndividual ,
                  :Country ;
         rdfs:comment "The Republic of Ireland, a European country." ;
         rdfs:label "Ireland" .


